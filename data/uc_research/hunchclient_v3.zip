<script type="text/javascript">
var seq = [38, 38, 40, 40, 37, 39, 37, 39, 66, 65], cur = 0, banners = [
	["halloween_2015.png", "halloween_2015_right.png"],
	["banner42.png", "b4rep.png"],
	["forum_header_halloween.gif", "halloween_top_x.jpg"],
	["xmas_2011.png", "xmas_2011_fade.png"],
	["xmas_2014.png", "xmas_2014_fade.png"],
	["uc_halloween_banner_2014_2.png", "uc_halloween_banner_2014_repeat3.jpg"],
	["feck_header.jpg", "feck_top_x.jpg"],
	["xmas_2012.png", "xmas_2012_fade.png"],
	["uc_summer2015banner.png", "uc_summer2015banner_x.png"],
	["xmas_2015.png", "xmas_2015_fade.png"],
    ["summer_2022_2.png", "summer_2022_2_x.png"],
    ["halloween2020.jpg", "halloween2020fade.jpg"]
], BASE_PATH = "/forum/ambience/misc/custom_headers/";
document.addEventListener("keyup", function(e) {
	if (e.keyCode == seq[cur]) {
		if (++cur == seq.length) {
			cur = 0;
			var e = document.getElementsByTagName("img"),
				banner = banners[Math.floor(banners.length * Math.random())];
			e[0].src = BASE_PATH + banner[0];
			if (banner[1])
				e[1].src = BASE_PATH + banner[1];
		}
	} else cur = 0;
});
</script>
